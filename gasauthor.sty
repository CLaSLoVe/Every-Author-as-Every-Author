% Layer 2 helper: scatter cited authors inside a rectangle of given size.
% Fair version: every cited author appears exactly \RefGasPerAuthor times.
\newcommand{\RefGasOverlay}[3]{%
  \begin{scope}
    \clip (0,0) rectangle (#1,#2);
    \@for\gasname:=#3\do{%
      \pgfmathtruncatemacro\gas@copies{\RefGasPerAuthor}%
      \expandafter\GasNameDimEstimate\expandafter{\gasname}%
      \pgfmathsetlengthmacro\gas@xmin{\gas@namew/2}%
      \pgfmathsetlengthmacro\gas@xmax{#1-\gas@namew/2}%
      \pgfmathsetlengthmacro\gas@ymin{\gas@nameh/2}%
      \pgfmathsetlengthmacro\gas@ymax{#2-\gas@nameh/2}%
      \foreach \gas@k in {1,...,\gas@copies}{%
        \expandafter\GasHash\expandafter{\gasname}%
        \pgfmathsetmacro\gashue{\thegashash/997*360}%
        \GasIsoColor{gasrefcol}{\gashue}%
        \edef\gasrx{\the\numexpr\pdfuniformdeviate 10001\relax}%
        \edef\gasry{\the\numexpr\pdfuniformdeviate 10001\relax}%
        \pgfmathparse{\gas@xmax<\gas@xmin ? 1 : 0}%
        \ifnum\pgfmathresult=1
          \pgfmathsetlengthmacro\gasx{#1/2}%
        \else
          \pgfmathsetlengthmacro\gasx{\gas@xmin+\gasrx/10000*(\gas@xmax-\gas@xmin)}%
        \fi
        \pgfmathparse{\gas@ymax<\gas@ymin ? 1 : 0}%
        \ifnum\pgfmathresult=1
          \pgfmathsetlengthmacro\gasy{#2/2}%
        \else
          \pgfmathsetlengthmacro\gasy{\gas@ymin+\gasry/10000*(\gas@ymax-\gas@ymin)}%
        \fi
        \node[text=gasrefcol,text opacity=\RefGasAlpha,inner sep=0pt,anchor=center]
          at (\gasx,\gasy) {\RefGasFont\gasname};%
      }%
    }%
  \end{scope}%
}

\newcommand{\gasbibitem}[3]{%
  \bibitem{#1}\leavevmode
  \setlength{\fboxsep}{\RefBoxSep}%
  \setlength{\fboxrule}{\RefBoxRule}%
  \sbox{\gas@refbox}{%
    \begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}
      #3%
    \end{minipage}%
  }%
  \noindent\begin{tikzpicture}[baseline=(gas@text.base)]
    \pgfmathsetlengthmacro\gas@refw{\linewidth}%
    \pgfmathsetlengthmacro\gas@innerx{\fboxrule+\fboxsep}%
    \pgfmathsetlengthmacro\gas@innerw{\linewidth-2*\fboxsep-2*\fboxrule}%
    \pgfmathsetlengthmacro\gas@contenth{\ht\gas@refbox+\dp\gas@refbox}%
    \pgfmathsetlengthmacro\gas@refh{\gas@contenth+2*\RefBoxVPad}%
    % Layer 1 — opaque white background over global page gas.
    \fill[\RefBoxFillColor] (0,0) rectangle (\gas@refw,\gas@refh);
    \draw[\RefBoxFrameColor,line width=\RefBoxRule] (0,0) rectangle (\gas@refw,\gas@refh);
    % Layer 2 — cited-author gas above the white fill, clipped to the box interior.
    \begin{scope}[shift={(\gas@innerx,0)}]
      \RefGasOverlay{\gas@innerw}{\gas@refh}{#2}%
    \end{scope}%
    % Layer 3 — reference body above the author gas.
    \node[anchor=south west,inner sep=0pt] (gas@text) at (\gas@innerx,\RefBoxVPad)
      {\usebox{\gas@refbox}};%
  \end{tikzpicture}\par
}
\makeatother

% Convenience environment. This is intentionally just a thin wrapper around
% the standard thebibliography environment.
\newenvironment{gasbibliography}[1]{%
  \begin{thebibliography}{#1}%
}{%
  \end{thebibliography}%
}
