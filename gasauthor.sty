% gasauthor.sty — Ideal-gas author block for LaTeX
% tcolorbox-free version: works on minimal TeX Live/BasicTeX installs.
%
% Bibliography (recommended — BibTeX workflow):
%   1. Add entries to references.bib
%   2. Cite with \cite{key} in the text
%   3. At the end of the document:
%        \bibliographystyle{gasbib}
%        \bibliography{references}
%   4. Build: pdflatex -> bibtex -> pdflatex -> pdflatex
%   Citations are numbered [1], [2], ... in order of first appearance (unsrt).
%
% Manual fallback (no BibTeX):
%   \begin{gasbibliography}{9}
%   \gasbibitem{key}{Author A,Author B}{remaining reference text, no authors}
%   \end{gasbibliography}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{gasauthor}[2026/06/11 Ideal-gas author block, tcolorbox-free]

\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{eso-pic}

% ------------------------- defaults -----------------------------------
\def\GasAuthors{Dian Jin,Weihao Cheng,Junze Yuan}
\def\GasCopies{36}
\def\GasAlpha{0.2}
\def\GasSeed{20260611}
\def\GasSat{0.60}
\def\GasLuma{0.42}
\def\GasHashMult{71}
\def\GasFont{\sffamily\bfseries\fontsize{10.5}{10.5}\selectfont}
% ----------------------------------------------------------------------

% --- hash a name to an integer in [0,996]: h <- (71*h + byte) mod 997.
\makeatletter
\newcounter{gashash}
\newcommand\GasHash[1]{%
  \setcounter{gashash}{7}%
  \@tfor\gas@t:=#1\do{%
    \setcounter{gashash}{\numexpr\value{gashash}*\GasHashMult+\expandafter`\gas@t\relax}%
    \setcounter{gashash}{\numexpr\value{gashash}-(\value{gashash}/997)*997\relax}%
    \ifnum\value{gashash}<0 \setcounter{gashash}{\numexpr\value{gashash}+997\relax}\fi
  }}
\makeatother

% --- iso-luminant color from hue.
\newcommand\GasIsoColor[2]{%
  \pgfmathsetmacro\gashp{mod(#2,360)/60}%
  \pgfmathsetmacro\gasC{\GasSat}%
  \pgfmathsetmacro\gasX{\GasSat*(1-abs(mod(\gashp,2)-1))}%
  \pgfmathsetmacro\gasm{1-\GasSat}%
  \pgfmathsetmacro\gasR{ifthenelse(\gashp<1,\gasC,ifthenelse(\gashp<2,\gasX,ifthenelse(\gashp<3,0,ifthenelse(\gashp<4,0,ifthenelse(\gashp<5,\gasX,\gasC)))))+\gasm}%
  \pgfmathsetmacro\gasG{ifthenelse(\gashp<1,\gasX,ifthenelse(\gashp<2,\gasC,ifthenelse(\gashp<3,\gasC,ifthenelse(\gashp<4,\gasX,0))))+\gasm}%
  \pgfmathsetmacro\gasB{ifthenelse(\gashp<2,0,ifthenelse(\gashp<3,\gasX,ifthenelse(\gashp<5,\gasC,\gasX)))+\gasm}%
  \pgfmathsetmacro\gasY{0.299*\gasR+0.587*\gasG+0.114*\gasB}%
  \pgfmathsetmacro\gasV{min(1,\GasLuma/\gasY)}%
  \pgfmathsetmacro\gasRf{\gasV*\gasR}%
  \pgfmathsetmacro\gasGf{\gasV*\gasG}%
  \pgfmathsetmacro\gasBf{\gasV*\gasB}%
  \definecolor{#1}{rgb}{\gasRf,\gasGf,\gasBf}}

% --- full-page author gas.
\newcommand\GasBackground{%
  \begin{tikzpicture}[overlay]
    \clip (0,0) rectangle (\paperwidth,\paperheight);
    \foreach \gasround in {1,...,\GasCopies}{%
      \foreach \gasname in \GasAuthors{%
        \expandafter\GasHash\expandafter{\gasname}%
        \pgfmathsetmacro\gashue{\thegashash/997*360}%
        \GasIsoColor{gascol}{\gashue}%
        \edef\gasrx{\the\numexpr\pdfuniformdeviate 10001\relax}%
        \edef\gasry{\the\numexpr\pdfuniformdeviate 10001\relax}%
        \pgfmathsetmacro\gasx{\gasrx/10000*\paperwidth}%
        \pgfmathsetmacro\gasy{\gasry/10000*\paperheight}%
        \node[text=gascol,text opacity=\GasAlpha,inner sep=0pt]
          at (\gasx pt,\gasy pt) {\GasFont\gasname};%
      }}%
  \end{tikzpicture}}
\AddToShipoutPictureBG{\GasBackground}

% -------------------- bibliography author gas -------------------------
% Each item is stacked in three layers inside one box:
%   (1) opaque white — masks global page gas
%   (2) cited-author gas — scattered over the box interior
%   (3) reference body — typeset on top for legibility
% Target total author-name instances per bibliography item. Split as evenly
% as possible across cited authors (12 over 2 authors -> 6 each; over 5 -> 3,3,2,2,2).
\def\RefGasPerAuthor{5}
\def\RefGasAlpha{0.2}
\newcommand\RefGasFont{\sffamily\bfseries\fontsize{6.2}{6.2}\selectfont}

\def\RefBoxFrameColor{black!35}
\def\RefBoxFillColor{white}
\def\RefBoxRule{0.4pt}
\def\RefBoxSep{4pt}
\newlength{\RefBoxVPad}
\setlength{\RefBoxVPad}{1.5\baselineskip}

\makeatletter
\newsavebox{\gas@refbox}

% Estimate rendered name size inside a tikzpicture (TeX measurement breaks there).
\newcommand{\GasNameDimEstimate}[1]{%
  \setcounter{gashash}{0}%
  \@tfor\gas@c:=#1\do{\advance\c@gashash by 1}%
  \pgfmathsetlengthmacro\gas@namew{\value{gashash}*3.8pt+6pt}%
  \pgfmathsetlengthmacro\gas@nameh{7.8pt}%
}

